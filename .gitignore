# =============================================================================
# XP3 PRO FOREX - .gitignore Profissional (v5.0.1)
# =============================================================================

# PYTHON ====================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.pytest_cache/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.mypy_cache/

# VIRTUAL ENVIRONMENTS ======================================================
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# IDE ======================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.settings/
*.iml

# LOGS =====================================================================
logs/*
!logs/.gitkeep
*.log
*.log.*
*.json.log

# DADOS DE RUNTIME E MERCADO ===============================================
data/*
!data/.gitkeep
*.db
*.sqlite3
*.csv
*.xlsx
*.json
!pyproject.toml
!src/**/*.json
!tests/**/*.json
!legacy/**/*.json

# RELATÓRIOS ===============================================================
reports/*
!reports/.gitkeep
ReportHistory-*.html
ReportHistory-*.png

# CONFIGURAÇÕES SENSÍVEIS ==================================================
.env
.env.*
!.env.example
config.json
secrets.json
mt5_credentials.json

